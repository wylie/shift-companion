{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*.ts",
    "server/**/*.ts",
    "src/data/mockData.ts",
    "src/lib/**/*.ts",
    "src/models/**/*.ts",
    "src/types.ts"
  ],
  "exclude": ["**/*.test.*", "server-dist", "dist"]
}
